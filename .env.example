# --- Supabase ---
# Find these in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- AI scoring backend (FastAPI) ---
# Default for local dev. Replace with your deployed URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Admin panel cron triggers ---
# Server-only secret (NOT exposed to the browser). MUST match the backend's CRON_SECRET.
# Used by app/(app)/admin/actions.ts to authenticate the "Run News Fetcher" and
# "Run AI Generator" buttons against the backend's /cron/* endpoints.
# Without this, admin trigger buttons get HTTP 401 from the backend.
CRON_SECRET=your-shared-cron-secret

# --- Razorpay payments ---
# Server-only (order create + verify + webhook):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Public (browser checkout):
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Webhook secret — set the same value in Razorpay Dashboard -> Webhooks.
# Until this is set, /api/razorpay/webhook is an inert 200 no-op.
RAZORPAY_WEBHOOK_SECRET=

# --- Supabase service role (server-only; NEVER prefix with NEXT_PUBLIC) ---
# Required by: Razorpay webhook + verify (bypass the 0006 column guard), the admin
# membership-grant + broadcast tools, and the email unsubscribe route.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email: transactional receipts (Google Workspace / Gmail SMTP) ---
# App Password from the sending account (Google Account -> Security -> 2-Step
# Verification -> App passwords). Powers the branded upgrade-confirmation email.
GMAIL_USER=team@mece.in
GMAIL_APP_PASSWORD=
# "From" header for all outgoing mail (used by both Google + Resend). Verified address.
EMAIL_FROM=MECE <team@mece.in>

# --- Email: bulk / promotional broadcasts (Resend) ---
# API key from resend.com; verify the mece.in sending domain in Resend first.
RESEND_API_KEY=
# Secret that signs one-click unsubscribe links (any long random string).
UNSUBSCRIBE_SECRET=

# --- Public site URL (absolute links in emails: logo, CTAs, unsubscribe) ---
NEXT_PUBLIC_SITE_URL=https://mece.in

# --- Telegram owner alerts (AI credit monitor: Admin -> AI usage) ---
# 1) Create a bot: message @BotFather on Telegram -> /newbot -> copy the token.
# 2) Send your new bot ANY message (it can't message you first), then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy message.chat.id.
# Both unset => alerts are silently disabled (dashboard shows "not configured").
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mirror of the backend's daily kill-switch budget (USD) so the admin dashboard's
# "today vs budget" card and the 80% burn alert use the same number. Default 10.
AI_DAILY_BUDGET_USD=10
