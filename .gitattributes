# Normalise line endings to LF in the repo. This ends the CRLF↔LF churn that
# was making every file show as "modified" in mixed Windows/Linux checkouts.
#
# After committing this file, renormalise once:
#   git add --renormalize .
#   git commit -m "chore: normalise line endings to LF"
#
* text=auto eol=lf

# Treat known binaries as binary (never normalise / diff as text).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
